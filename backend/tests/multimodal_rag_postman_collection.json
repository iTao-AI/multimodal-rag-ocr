{
  "info": {
    "name": "Multimodal RAG Backend API",
    "description": "多模态 RAG 后端服务 API 测试集合",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url_pdf",
      "value": "http://localhost:8006",
      "type": "string"
    },
    {
      "key": "base_url_chunker",
      "value": "http://localhost:8001",
      "type": "string"
    },
    {
      "key": "base_url_milvus",
      "value": "http://localhost:8000",
      "type": "string"
    },
    {
      "key": "base_url_chat",
      "value": "http://localhost:8501",
      "type": "string"
    },
    {
      "key": "api_key",
      "value": "sk-your-api-key",
      "type": "string"
    },
    {
      "key": "collection_name",
      "value": "test_docs",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "PDF 提取服务 (8006)",
      "item": [
        {
          "name": "健康检查",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url_pdf}}/health",
              "host": ["{{base_url_pdf}}"],
              "path": ["health"]
            }
          }
        },
        {
          "name": "API 文档",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url_pdf}}/docs",
              "host": ["{{base_url_pdf}}"],
              "path": ["docs"]
            }
          }
        },
        {
          "name": "快速提取 PDF",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "/path/to/your/test.pdf"
                },
                {
                  "key": "mode",
                  "value": "fast",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{base_url_pdf}}/extract/fast",
              "host": ["{{base_url_pdf}}"],
              "path": ["extract", "fast"]
            }
          }
        },
        {
          "name": "精确提取 PDF",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"api_key\": \"{{api_key}}\",\n  \"model_name\": \"qwen3-vl-plus\",\n  \"model_url\": \"https://dashscope.aliyuncs.com/compatible-mode/v1\"\n}"
            },
            "url": {
              "raw": "{{base_url_pdf}}/extract/accurate",
              "host": ["{{base_url_pdf}}"],
              "path": ["extract", "accurate"]
            }
          }
        }
      ]
    },
    {
      "name": "文本切分服务 (8001)",
      "item": [
        {
          "name": "API 文档",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url_chunker}}/docs",
              "host": ["{{base_url_chunker}}"],
              "path": ["docs"]
            }
          }
        },
        {
          "name": "基础文本切分",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"这是一个测试文本。\" * 100,\n  \"chunk_size\": 500,\n  \"chunk_overlap\": 50\n}"
            },
            "url": {
              "raw": "{{base_url_chunker}}/chunk",
              "host": ["{{base_url_chunker}}"],
              "path": ["chunk"]
            }
          }
        },
        {
          "name": "Markdown 文本切分",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"markdown_text\": \"# 标题\\n\\n这是内容。\\n\\n## 子标题\\n\\n更多内容。\",\n  \"min_chunk_size\": 100,\n  \"max_chunk_size\": 1000\n}"
            },
            "url": {
              "raw": "{{base_url_chunker}}/chunk/markdown",
              "host": ["{{base_url_chunker}}"],
              "path": ["chunk", "markdown"]
            }
          }
        }
      ]
    },
    {
      "name": "Milvus API 服务 (8000)",
      "item": [
        {
          "name": "健康检查",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url_milvus}}/health",
              "host": ["{{base_url_milvus}}"],
              "path": ["health"]
            }
          }
        },
        {
          "name": "API 文档",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url_milvus}}/docs",
              "host": ["{{base_url_milvus}}"],
              "path": ["docs"]
            }
          }
        },
        {
          "name": "获取集合列表",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url_milvus}}/collections",
              "host": ["{{base_url_milvus}}"],
              "path": ["collections"]
            }
          }
        },
        {
          "name": "向量检索",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"collection_name\": \"{{collection_name}}\",\n  \"query_text\": \"测试查询\",\n  \"top_k\": 5\n}"
            },
            "url": {
              "raw": "{{base_url_milvus}}/search",
              "host": ["{{base_url_milvus}}"],
              "path": ["search"]
            }
          }
        }
      ]
    },
    {
      "name": "对话检索服务 (8501)",
      "item": [
        {
          "name": "健康检查",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url_chat}}/health",
              "host": ["{{base_url_chat}}"],
              "path": ["health"]
            }
          }
        },
        {
          "name": "API 文档",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url_chat}}/docs",
              "host": ["{{base_url_chat}}"],
              "path": ["docs"]
            }
          }
        },
        {
          "name": "对话问答",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"什么是 RAG？\",\n  \"collection_name\": \"{{collection_name}}\",\n  \"llm_config\": {\n    \"api_url\": \"https://dashscope.aliyuncs.com/compatible-mode/v1\",\n    \"api_key\": \"{{api_key}}\",\n    \"model_name\": \"qwen3-vl-plus\"\n  },\n  \"top_k\": 5,\n  \"stream\": false,\n  \"return_source\": true\n}"
            },
            "url": {
              "raw": "{{base_url_chat}}/chat",
              "host": ["{{base_url_chat}}"],
              "path": ["chat"]
            }
          }
        }
      ]
    }
  ]
}
