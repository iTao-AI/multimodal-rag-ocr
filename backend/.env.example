# ============ 生成模型（多模态）服务配置 ============
# 如果用OpenAI
# MODEL_URL = "https://api.openai.com/v1"
# API_KEY = "GrkewjMOK7I0"
# MODEL_NAME = "gpt-4o"

# 如果用Qwen
API_KEY = "your-dashscope-api-key"
MODEL_NAME = "qwen3-vl-plus"
MODEL_URL = "https://dashscope.aliyuncs.com/compatible-mode/v1"

# ============ 向量嵌入服务配置 ============

# Embedding API配置
EMBEDDING_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL_NAME=text-embedding-v4
EMBEDDING_API_KEY=your-dashscope-embedding-api-key

# ============ PDF 上传和提取服务配置 ============

# PDF上传文件存储路径
UPLOAD_BASE_DIR=/Users/mac/Developer/Projects/Active/multimodal-rag-ocr/backend/output/uploads

# PDF提取结果存储路径
EXTRACTION_RESULTS_DIR=/Users/mac/Developer/Projects/Active/multimodal-rag-ocr/backend/output/extraction_results

# 文件大小限制（MB）
MAX_FILE_SIZE_MB=50

# 信息抽取服务端口配置
INFOR_EXTRAC_SERVICE_PORT=8006
INFOR_EXTRAC_SERVICE_HOST=0.0.0.0

CHUNK_SERVICE_PORT=8001
CHUNK_SERVICE_HOST=0.0.0.0


# 是否启用自动切分
CHUNKING_SERVICE_ENABLED=true

# ============ Milvus 向量数据库配置 ============

# Milvus服务地址（通过Docker部署在本地）
MILVUS_HOST=localhost
MILVUS_PORT=19530

# ============ Milvus API服务配置 ============

# Milvus API服务地址
MILVUS_API_HOST=0.0.0.0
MILVUS_API_PORT=8000
MILVUS_API_ENABLED=true


CHAT_SERVICE_PORT=8501
CHAT_SERVICE_HOST=0.0.0.0



# MinerU 解析后的可视化图片存储地址
MINERU_VIZ_DIR=/Users/mac/Developer/Projects/Active/multimodal-rag-ocr/backend/mineru_visualizations


# OCR V2 服务地址（需 AutoDL GPU 服务器，本地不可用）
DEEPSEEK_OCR_API_URL=http://localhost:8705/v1/ocr/pdf
DEEPSEEK_OCR_DPI=144
DEEPSEEK_ENABLE_IMAGE_DESC=true
DEEPSEEK_DRAW_BBOX=true

# MinerU OCR 服务（需 AutoDL GPU 服务器）
MINERU_API_URL=http://localhost:10010/file_parse
VLLM_SERVER_URL=http://localhost:30000
MINERU_BACKEND=pipeline

# API 地址
PADDLEOCR_VL_API_URL=http://localhost:8802/parse

# 超时时间（秒）
PADDLEOCR_VL_TIMEOUT=600

# ============ 检索增强 (V2.1) ============

# Redis 缓存
CACHE_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
CACHE_TTL_SECONDS=3600

# 混合检索 (BM25 + 向量融合)
HYBRID_SEARCH_ENABLED=true
BM25_WEIGHT=0.3
VECTOR_WEIGHT=0.7
HYBRID_TOP_K=50
HYBRID_FINAL_TOP_K=10

# 查询改写
QUERY_REWRITE_ENABLED=true
QUERY_REWRITE_VARIATIONS=3