# 前端环境变量配置模板
# 复制此文件为 .env 或 .env.local 并根据实际情况修改

# ==================== 后端服务地址 ====================

# Milvus 向量数据库 API (默认: http://localhost:8000)
VITE_MILVUS_API_URL=http://localhost:8000

# 对话检索服务 (默认: http://localhost:8501)
VITE_CHAT_API_URL=http://localhost:8501

# PDF 提取服务 (默认: http://localhost:8006)
VITE_EXTRACTION_API_URL=http://localhost:8006

# 文本切分服务 (默认: http://localhost:8001)
VITE_CHUNK_API_URL=http://localhost:8001

# ==================== 部署场景示例 ====================

# 场景1: 本地开发（所有服务在本机）
# VITE_MILVUS_API_URL=http://localhost:8000
# VITE_CHAT_API_URL=http://localhost:8501
# VITE_EXTRACTION_API_URL=http://localhost:8006
# VITE_CHUNK_API_URL=http://localhost:8001

# 场景2: 远程服务器部署（修改为实际IP）
# VITE_MILVUS_API_URL=http://your-server-ip:8000
# VITE_CHAT_API_URL=http://your-server-ip:8501
# VITE_EXTRACTION_API_URL=http://your-server-ip:8006
# VITE_CHUNK_API_URL=http://your-server-ip:8001

# 场景3: 生产环境（使用域名）
# VITE_MILVUS_API_URL=https://api.yourdomain.com/milvus
# VITE_CHAT_API_URL=https://api.yourdomain.com/chat
# VITE_EXTRACTION_API_URL=https://api.yourdomain.com/extraction
# VITE_CHUNK_API_URL=https://api.yourdomain.com/chunk

